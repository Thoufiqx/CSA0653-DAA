# ERROR CODE

def string_match_error(text, pattern):
    n = len(text)
    m = len(pattern)

    for i in range(n - m):      # ERROR
        j = 0

        while j < m and text[i + j] == pattern[j]:
            j += 1

        if j == m:
            return i

    return -1


# CORRECTED CODE

def string_match(text, pattern):
    n = len(text)
    m = len(pattern)

    for i in range(n - m + 1):   # FIXED
        j = 0

        while j < m and text[i + j] == pattern[j]:
            j += 1

        if j == m:
            return i

    return -1


# INPUT
text = "HELLOWORLD"
pattern = "WORLD"

result = string_match(text, pattern)

print("Text:", text)
print("Pattern:", pattern)

if result != -1:
    print("Pattern found at index:", result)
else:
    print("Pattern not found")

